+TEST_F(RemoteEventTest, CAbiDeferredTimeoutReturnsCanonicalErrorExactlyOnce)
+{
+    const QString moduleName = QStringLiteral("lp_async_timeout_module");
+    const QString registryUrl = LogosInstance::id(moduleName);
+
+    RemoteTransportHost host(registryUrl);
+    DeferredProvider provider;
+    ModuleProxy proxy(&provider);
+    ASSERT_TRUE(proxy.saveToken(QStringLiteral("test_caller"),
+                                QStringLiteral("tok-1")));
+    ASSERT_TRUE(host.publishObject(moduleName, &proxy));
+    ASSERT_EQ(lp_set_mode("remote"), LP_OK);
+    ASSERT_EQ(lp_token_save("lp_async_timeout_module", "tok-1"), LP_OK);
+
+    lp_client* client = lp_client_create(
+        "lp_async_timeout_module", "test_caller", nullptr, nullptr);
+    ASSERT_NE(client, nullptr);
+    struct Capture {
+        std::atomic<int> delivered{0};
+        int ok = 1;
+        std::string json;
+    } capture;
+
+    ASSERT_EQ(lp_invoke_async(client, "asyncWork", "[]", 50,
+        [](int ok, const char* json, void* data) {
+            auto* capture = static_cast<Capture*>(data);
+            capture->ok = ok;
+            capture->json = json ? json : "";
+            capture->delivered.fetch_add(1);
+        }, &capture), LP_OK);
