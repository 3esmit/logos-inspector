+class PlainServerGuard {
+public:
+    PlainServerGuard()
+        : work(boost::asio::make_work_guard(io))
+        , server(std::make_shared<logos::plain::RpcServerTcp>(
+              io, "127.0.0.1", 0,
+              std::make_shared<logos::plain::JsonCodec>(), &handler))
+        , worker([this] { io.run(); })
+    {
+    }
+
+    ~PlainServerGuard()
+    {
+        server->stop();
+        work.reset();
+        io.stop();
+        if (worker.joinable()) worker.join();
+    }
+
+    bool start() { return server->start(); }
+    uint16_t port() const { return server->boundPort(); }
+
+private:
+    NullResultHandler handler;
+    boost::asio::io_context io;
+    boost::asio::executor_work_guard<boost::asio::io_context::executor_type> work;
+    std::shared_ptr<logos::plain::RpcServerTcp> server;
+    std::thread worker;
