+        // (mnemonics, passwords, tokens, key material). Log only the method name
+        // and argument count, matching the other transport call sites.
+        qDebug() << "ModuleProxy: callRemoteMethod" << methodName
+                 << "args:" << args.size();
+        return logos::AsyncCallOutcome::success(
+            m_provider->callMethod(methodName, args));
+    } catch (const std::exception& error) {
+        qWarning() << "ModuleProxy: provider call failed for" << methodName
+                   << ":" << error.what();
+        return logos::AsyncCallOutcome::failure(
+            "invoke_failed", "module provider failed during dispatch", origin);
+    } catch (...) {
+        qWarning() << "ModuleProxy: provider call failed for" << methodName;
+        return logos::AsyncCallOutcome::failure(
+            "invoke_failed", "module provider failed during dispatch", origin);
+    }
 }
 
