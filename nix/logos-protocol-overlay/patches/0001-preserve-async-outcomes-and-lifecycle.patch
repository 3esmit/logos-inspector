+bool waitUntil(const std::atomic<bool>& flag,
+               std::chrono::milliseconds timeout = std::chrono::seconds(5))
+{
+    const auto deadline = std::chrono::steady_clock::now() + timeout;
+    while (!flag.load() && std::chrono::steady_clock::now() < deadline)
+        std::this_thread::sleep_for(std::chrono::milliseconds(1));
+    return flag.load();
+}
+
+class ThreadGate {
+public:
+    void block()
+    {
+        std::unique_lock<std::mutex> lock(m_mutex);
+        m_entered = true;
+        m_changed.notify_all();
+        m_changed.wait(lock, [this]() { return m_released; });
+    }
+
+    bool waitUntilEntered()
+    {
+        std::unique_lock<std::mutex> lock(m_mutex);
+        return m_changed.wait_for(lock, std::chrono::seconds(5),
+                                  [this]() { return m_entered; });
+    }
+
+    void release()
+    {
+        std::lock_guard<std::mutex> lock(m_mutex);
+        m_released = true;
+        m_changed.notify_all();
+    }
+
+private:
+    std::mutex m_mutex;
+    std::condition_variable m_changed;
+    bool m_entered = false;
+    bool m_released = false;
+};
+
+// Runs a real qt_local client, its ModuleProxy, and event callbacks on a
+// dedicated Qt owner thread. Tests stay on the main thread so a lifecycle
+// regression is bounded by CTest's timeout instead of freezing all assertions.
+class LocalOwnerHarness {
+public:
+    explicit LocalOwnerHarness(std::string moduleName)
+        : m_moduleName(std::move(moduleName))
+        , m_context(new QObject())
+    {
+        m_owner.start();
+        m_context->moveToThread(&m_owner);
+        QMetaObject::invokeMethod(m_context, [this]() {
+            m_proxy = new ModuleProxy(nullptr);
+            m_client = lp_client_create(
+                m_moduleName.c_str(), "owner_race_origin", nullptr, nullptr);
+        }, Qt::BlockingQueuedConnection);
+        PluginRegistry::registerPlugin(
+            m_proxy, QString::fromStdString(m_moduleName));
+    }
+
+    ~LocalOwnerHarness()
+    {
+        if (m_client) lp_client_destroy(m_client);
+        PluginRegistry::unregisterPlugin(
+            QString::fromStdString(m_moduleName));
+        QMetaObject::invokeMethod(m_context, [this]() {
+            delete m_proxy;
+            m_proxy = nullptr;
+        }, Qt::BlockingQueuedConnection);
+        QThread* mainThread = QCoreApplication::instance()->thread();
+        QMetaObject::invokeMethod(m_context, [this, mainThread]() {
+            m_context->moveToThread(mainThread);
+        }, Qt::BlockingQueuedConnection);
+        m_owner.quit();
+        m_owner.wait();
+        delete m_context;
+    }
+
+    LocalOwnerHarness(const LocalOwnerHarness&) = delete;
+    LocalOwnerHarness& operator=(const LocalOwnerHarness&) = delete;
+
+    lp_client* client() const { return m_client; }
+    lp_client* takeClient() { return std::exchange(m_client, nullptr); }
+    QObject* context() const { return m_context; }
+
+    bool queueEvent(const QString& name, const QVariantList& data = {})
+    {
+        return QMetaObject::invokeMethod(
+            m_proxy, "eventResponse", Qt::QueuedConnection,
+            Q_ARG(QString, name), Q_ARG(QVariantList, data));
+    }
+
+private:
+    std::string m_moduleName;
+    QThread m_owner;
+    QObject* m_context = nullptr;
+    ModuleProxy* m_proxy = nullptr;
+    lp_client* m_client = nullptr;
+};
+
