+    }
+    std::this_thread::sleep_for(std::chrono::milliseconds(20));
+
+    EXPECT_EQ(callbackCount.load(), 1);
+    EXPECT_EQ(ok, 1);
+    EXPECT_EQ(json, "null");
+    EXPECT_NE(callbackThread, callerThread);
+    lp_client_destroy(client);
+}
