+class OutcomeProvider final : public LogosProviderObject {
+public:
+    QVariant callMethod(const QString& method, const QVariantList&) override
+    {
+        ++calls;
+        if (method == QLatin1String("throws"))
+            throw std::runtime_error("provider failure");
+        return QVariant();
+    }
+
+    bool informModuleToken(const QString&, const QString&) override { return true; }
+
+    QJsonArray getMethods() override
+    {
+        return {
+            QJsonObject{
+                { QStringLiteral("name"), QStringLiteral("returnsNull") },
+                { QStringLiteral("isInvokable"), true },
+            },
+            QJsonObject{
+                { QStringLiteral("name"), QStringLiteral("throws") },
+                { QStringLiteral("isInvokable"), true },
+            },
+        };
+    }
+
+    void setEventListener(EventCallback) override {}
+    void init(void*) override {}
+    QString providerName() const override { return QStringLiteral("outcome_module"); }
+    QString providerVersion() const override { return QStringLiteral("1.0.0"); }
+
+    std::atomic<int> calls{0};
+};
+
+logos::AsyncCallOutcome invoke(LogosObject* object,
+                               const QString& token,
+                               const QString& method)
+{
+    std::optional<logos::AsyncCallOutcome> captured;
+    std::atomic<int> callbackCount{0};
+    object->callMethodAsyncOutcome(token, method, {}, 1000,
+        [&captured, &callbackCount](logos::AsyncCallOutcome outcome) {
+            captured = std::move(outcome);
+            ++callbackCount;
+        });
+
+    const auto deadline = std::chrono::steady_clock::now()
+        + std::chrono::seconds(5);
+    while (!captured && std::chrono::steady_clock::now() < deadline) {
+        QCoreApplication::processEvents();
+        std::this_thread::sleep_for(std::chrono::milliseconds(1));
+    }
+    EXPECT_TRUE(captured.has_value());
+    EXPECT_EQ(callbackCount.load(), 1);
+    return captured.value_or(logos::AsyncCallOutcome::failure(
+        "test_timeout", "local callback was not delivered", "outcome_module"));
+}
