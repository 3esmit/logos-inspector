+TEST_F(LpClientTest, ReentrantDestroyDuringConcurrentCloseReturnsSafely)
+{
+    m_mock->when("mod", "closeRace").thenReturn(QVariant(9));
+    lp_client* client = lp_client_create("mod", "origin", nullptr, nullptr);
+    ASSERT_NE(client, nullptr);
+
+    struct Context {
+        lp_client* client = nullptr;
+        std::atomic<bool> callbackEntered{false};
+        std::atomic<bool> outerStarted{false};
+        std::atomic<bool> nestedReturned{false};
+        std::atomic<bool> outerReturned{false};
+        std::thread destroyer;
+    } context{ client };
+
+    ASSERT_EQ(lp_invoke_async(client, "closeRace", "[]", 1000,
+        [](int, const char*, void* data) {
+            auto* context = static_cast<Context*>(data);
+            context->callbackEntered = true;
+            context->destroyer = std::thread([context] {
+                context->outerStarted = true;
+                lp_client_destroy(context->client);
+                context->outerReturned = true;
+            });
+            while (!context->outerStarted.load()) std::this_thread::yield();
+
+            // Wait until the foreign destroyer has marked the handle closing.
+            // Calls admitted before that transition are harmless: teardown's
+            // callback guard drops their queued completions.
+            int status = LP_OK;
+            QElapsedTimer timer;
+            timer.start();
+            while (status != LP_ERR_UNAVAILABLE && timer.elapsed() < 5000) {
+                status = lp_invoke_async(
+                    context->client, "closeRace", "[]", 1000,
+                    [](int, const char*, void*) {}, nullptr);
+                std::this_thread::yield();
+            }
+            if (status == LP_ERR_UNAVAILABLE) {
+                lp_client_destroy(context->client);
+                context->nestedReturned = true;
+            }
+        }, &context), LP_OK);
+
+    QElapsedTimer timer;
+    timer.start();
+    while (!context.outerReturned.load() && timer.elapsed() < 5000)
+        QCoreApplication::processEvents(QEventLoop::AllEvents, 50);
+    if (context.destroyer.joinable()) context.destroyer.join();
+
+    EXPECT_TRUE(context.callbackEntered.load());
+    EXPECT_TRUE(context.nestedReturned.load());
+    EXPECT_TRUE(context.outerReturned.load());
+}
