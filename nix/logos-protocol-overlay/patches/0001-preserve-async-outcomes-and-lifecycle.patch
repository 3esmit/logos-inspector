+TEST_F(ConcurrentDispatchTest, AsyncWaiterSurvivesImmediateObjectRelease)
+{
+    LogosTransportConfig cfg;
+    cfg.protocol = LogosProtocol::Tcp;
+    cfg.host = "127.0.0.1";
+    cfg.port = 0;
+
+    auto host = std::make_unique<PlainTransportHost>(cfg);
+    ASSERT_TRUE(host->start());
+
+    SlowProvider provider(/*multi=*/true);
+    ModuleProxy proxy(&provider);
+    proxy.saveToken(QStringLiteral("core"), QStringLiteral("tok"));
+    ASSERT_TRUE(host->publishObject("slow_mod", &proxy));
+
+    const QString endpoint = host->endpoint();
+    const uint16_t port = endpoint.mid(endpoint.lastIndexOf(':') + 1).toUShort();
+    LogosTransportConfig clientCfg = cfg;
+    clientCfg.port = port;
+    auto connection = std::make_unique<PlainTransportConnection>(clientCfg);
+    ASSERT_TRUE(connection->connectToHost());
+
+    LogosObject* object = connection->requestObject("slow_mod", 2000);
+    ASSERT_NE(object, nullptr);
+
+    std::atomic<bool> done{false};
+    bool ok = true;
+    std::string errorCode;
+    object->callMethodAsyncOutcome(
+        QStringLiteral("tok"), QStringLiteral("slow"), QVariantList{ 300 }, 100,
+        [&done, &ok, &errorCode](logos::AsyncCallOutcome outcome) {
+            ok = outcome.ok();
+            errorCode = outcome.error.code;
+            done = true;
+        });
+
+    // The public handle may be released as soon as asynchronous admission
+    // returns. Its detached waiter must retain only shared rendezvous state,
+    // never dereference the deleted PlainLogosObject.
+    object->release();
+
+    for (int i = 0; i < 500 && !done.load(); ++i) {
+        QCoreApplication::processEvents();
+        std::this_thread::sleep_for(std::chrono::milliseconds(10));
+    }
+    ASSERT_TRUE(done.load());
+    EXPECT_FALSE(ok);
+    EXPECT_EQ(errorCode, "timeout");
+
+    // Let SlowProvider's detached completion worker finish before its fixture
+    // storage is destroyed.
+    for (int i = 0; i < 40; ++i) {
+        QCoreApplication::processEvents();
+        std::this_thread::sleep_for(std::chrono::milliseconds(10));
+    }
+}
