+TEST_F(LpClientTest, ForeignApisDoNotPinLifecycleAcrossOwnerDispatch)
+{
+    enum class ForeignApi { Invoke, Subscribe, GetMethods, InformToken };
+    const std::vector<ForeignApi> cases{
+        ForeignApi::Invoke,
+        ForeignApi::Subscribe,
+        ForeignApi::GetMethods,
+        ForeignApi::InformToken,
+    };
+
+    int caseNumber = 0;
+    for (const ForeignApi api : cases) {
+        SCOPED_TRACE(caseNumber);
+        ASSERT_EQ(lp_set_mode("local"), LP_OK);
+        LocalOwnerHarness harness(
+            "lifecycle_api_mod_" + std::to_string(caseNumber++));
+        ASSERT_NE(harness.client(), nullptr);
+
+        struct RaceContext {
+            ForeignApi api;
+            lp_client* client;
+            std::thread worker;
+            std::atomic<bool> foreignStarted{false};
+            std::atomic<bool> foreignReturned{false};
+            std::atomic<bool> reentrantReturned{false};
+            lp_subscription* extraSubscription = nullptr;
+        } context{ api, harness.client() };
+
+        lp_subscription* trigger = lp_subscribe(
+            harness.client(), "race",
+            [](const char*, const char*, void* data) {
+                auto* context = static_cast<RaceContext*>(data);
+                context->worker = std::thread([context]() {
+                    context->foreignStarted = true;
+                    switch (context->api) {
+                    case ForeignApi::Invoke: {
+                        char* result = nullptr;
+                        char* error = nullptr;
+                        (void)lp_invoke(context->client, "noop", "[]", 1000,
+                                        &result, &error);
+                        lp_string_free(result);
+                        lp_string_free(error);
+                        break;
+                    }
+                    case ForeignApi::Subscribe:
+                        context->extraSubscription = lp_subscribe(
+                            context->client, "other",
+                            [](const char*, const char*, void*) {}, nullptr);
+                        break;
+                    case ForeignApi::GetMethods: {
+                        char* methods = lp_get_methods(context->client);
+                        lp_string_free(methods);
+                        break;
+                    }
+                    case ForeignApi::InformToken:
+                        (void)lp_inform_module_token(
+                            context->client, "auth", "origin", "token");
+                        break;
+                    }
+                    context->foreignReturned = true;
+                });
+                while (!context->foreignStarted.load())
+                    std::this_thread::yield();
+                std::this_thread::sleep_for(std::chrono::milliseconds(50));
+
+                // Old code blocks here: the foreign API owns lifecycle while
+                // waiting for this same owner thread. A lease leaves lifecycle
+                // unlocked, so callback re-entry remains admissible.
+                const int status = lp_invoke_async(
+                    context->client, "reentrant", "[]", 1000,
+                    [](int, const char*, void*) {}, nullptr);
+                context->reentrantReturned = status == LP_OK;
+            }, &context);
+        ASSERT_NE(trigger, nullptr);
+        ASSERT_TRUE(harness.queueEvent(QStringLiteral("race"), { 1 }));
+        ASSERT_TRUE(waitUntil(context.reentrantReturned));
+        ASSERT_TRUE(waitUntil(context.foreignReturned));
+        context.worker.join();
+        if (context.extraSubscription)
+            lp_unsubscribe(context.extraSubscription);
+        lp_unsubscribe(trigger);
+    }
+}
