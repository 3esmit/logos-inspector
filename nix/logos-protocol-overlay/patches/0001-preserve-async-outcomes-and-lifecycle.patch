+class NullResultHandler final : public logos::plain::IncomingCallHandler {
+public:
+    void onCall(const logos::plain::CallMessage& request,
+                CallReply reply) override
+    {
+        logos::plain::ResultMessage result;
+        result.id = request.id;
+        result.ok = true;
